# Purpose: 为 Gazebo Harmonic 仿真新增 FAST-LIO 配置 gazebo_velodyne.yaml
#          (velodyne 16线 / 仿真话题 points_raw + /imu_plugin/out / lidar-imu 外参归零 / 纯里程计)
# Base:    FAST_LIO @ a4743b0 (ROS2 branch)
# Apply:   cd core/localization/FAST_LIO && git apply ../fast-lio2.patch
# Depends: 需配合 core/localization/livox_ros_driver2 消息桩包方可编译
# Note:    本补丁中性(仅新增配置文件),对真实场景无害。改变核心行为的去畸变开关在 sim-only/ 下。
#          外参 [0,0,0]:新机器人 velodyne 与 imu_link 同位置(robot_macro.urdf.xacro,均挂 base_link
#          的 xyz="0 0 sensor_z"),雷达-IMU 外参恒等;与 mapping(LIO-SAM)的 extrinsicTrans:[0,0,0] 一致。
#
diff --git a/config/gazebo_velodyne.yaml b/config/gazebo_velodyne.yaml
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/config/gazebo_velodyne.yaml
@@ -0,0 +1,46 @@
+/**:
+    ros__parameters:
+        feature_extract_enable: false
+        point_filter_num: 4
+        max_iteration: 3
+        filter_size_surf: 0.5
+        filter_size_map: 0.5
+        cube_side_length: 1000.0
+        runtime_pos_log_enable: false
+        map_file_path: "./test.pcd"
+
+        common:
+            lid_topic:  "points_raw"
+            imu_topic:  "/imu_plugin/out"
+            time_sync_en: false
+            time_offset_lidar_to_imu: 0.0
+
+        preprocess:
+            lidar_type: 2
+            scan_line: 16
+            scan_rate: 10
+            timestamp_unit: 2
+            blind: 1.0
+
+        mapping:
+            acc_cov: 0.1
+            gyr_cov: 0.1
+            b_acc_cov: 0.0001
+            b_gyr_cov: 0.0001
+            fov_degree:    360.0
+            det_range:     100.0
+            extrinsic_est_en:  true
+            extrinsic_T: [ 0.0, 0.0, 0.0 ]
+            extrinsic_R: [ 1., 0., 0.,
+                           0., 1., 0.,
+                           0., 0., 1.]
+
+        publish:
+            path_en:  false
+            scan_publish_en:  true
+            dense_publish_en: true
+            scan_bodyframe_pub_en: true
+
+        pcd_save:
+            pcd_save_en: false
+            interval: -1
